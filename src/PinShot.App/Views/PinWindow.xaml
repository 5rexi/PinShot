<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PinShot.App.Views.PinWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PinShot Pin">
    <Grid
        x:Name="Root"
        Background="Transparent"
        DoubleTapped="Root_DoubleTapped"
        KeyDown="Root_KeyDown"
        PointerMoved="Root_PointerMoved"
        PointerPressed="Root_PointerPressed"
        PointerReleased="Root_PointerReleased"
        PointerWheelChanged="Root_PointerWheelChanged"
        RightTapped="Root_RightTapped"
        TabIndex="0">
        <Border
            x:Name="Chrome"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Image
                x:Name="PinnedImage"
                Stretch="UniformToFill" />
        </Border>
    </Grid>
</Window>
